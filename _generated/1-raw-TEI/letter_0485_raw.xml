   <text>
      <body>
         <div type="letter">
            <pb xml:id="letter_0485_001"
                facs="https://iiif.ub.unibe.ch/image/v3/schwarzenbach/letter_0485_001.jpg"/>
            <milestone unit="textregion" xml:id="letter_0485_001_tr_2"/>
            <lb xml:id="letter_0485_001_tr_2_tl_2"/>THE BELVEDERE 11. Dez. 36
<lb xml:id="letter_0485_001_tr_2_tl_3"/><PAGE tag="italic">at</PAGE> BALTIMORE<CONV tag="p">
<lb xml:id="letter_0485_001_tr_2_tl_4"/>Lieber Bobby – ganz sicher werde ich
<lb xml:id="letter_0485_001_tr_2_tl_5"/>die prächtigen u. pfundigen U.S.A.-
<lb xml:id="letter_0485_001_tr_2_tl_6"/>Lokomotiven für Dich photographieren –
<lb xml:id="letter_0485_001_tr_2_tl_7"/>u. liebes Busy, ich wünschte ich
<lb xml:id="letter_0485_001_tr_2_tl_8"/>wäre über Weihnachten mit Euch
<lb xml:id="letter_0485_001_tr_2_tl_9"/>oben im Engadin. Ihr müsst
<lb xml:id="letter_0485_001_tr_2_tl_10"/>alles tausendmal von mir
<lb xml:id="letter_0485_001_tr_2_tl_11"/>grüssen!</CONV><CONV tag="p">
<lb xml:id="letter_0485_001_tr_2_tl_12"/>Erika hat am <PAGE tag="underlined">28.</PAGE> Premiere –<!--FML: this needs attention (was tagged as "fml" in Transkribus)--></CONV><milestone unit="textregion" xml:id="letter_0485_001_tr_1"/>
            <lb xml:id="letter_0485_001_l"/>
            <!--FML: this needs attention (was tagged as "fml" in Transkribus)--><CONV tag="p">
<lb xml:id="letter_0485_001_l"/>ich werde Euch Ausschnitte,
<lb xml:id="letter_0485_001_tr_1_tl_3"/>Program[m] etc. schicken u.
<lb xml:id="letter_0485_001_tr_1_tl_4"/>alles richtig beschreiben –
<lb xml:id="letter_0485_001_tr_1_tl_5"/>Inzwischen haltet Ihr den
<lb xml:id="letter_0485_001_tr_1_tl_6"/>Daumen!! –</CONV><CONV tag="p">
<lb xml:id="letter_0485_001_tr_1_tl_7"/>Ich bin hier, um über Wally
<lb xml:id="letter_0485_001_tr_1_tl_8"/>Simpsons Heimatstadt zu
<lb xml:id="letter_0485_001_tr_1_tl_9"/>schreiben – es ist eine sonderbare
<lb xml:id="letter_0485_001_tr_1_tl_10"/>Geschichte, u. recht beeindruckend –</CONV>
<lb xml:id="letter_0485_001_tr_1_tl_11"/>Seid zu Neujahr gegrüsst u.
<lb xml:id="letter_0485_001_tr_1_tl_12"/>umarmt, bleibt gesund –
<lb xml:id="letter_0485_001_tr_1_tl_13"/>u. habt es sehr, sehr schön!
<lb xml:id="letter_0485_001_tr_1_tl_14"/>Eure
<lb xml:id="letter_0485_001_tr_1_tl_15"/>An[n]emarie
<lb xml:id="letter_0485_001_tr_1_tl_16"/>WENDEN [Pfeil nach unten]<pb xml:id="letter_0485_002"
                facs="https://iiif.ub.unibe.ch/image/v3/schwarzenbach/letter_0485_002.jpg"/>
            <milestone unit="textregion" xml:id="letter_0485_002_tr_1"/>
            <lb xml:id="letter_0485_002_tr_1_tl_1"/>Grüsst:
<lb xml:id="letter_0485_002_tr_1_tl_2"/>Jecklin, Hans, – Lina,
<lb xml:id="letter_0485_002_tr_1_tl_3"/>Herrn Stettler, [space]
<lb xml:id="letter_0485_002_tr_1_tl_4"/><PAGE tag="underlined">Eure Buben</PAGE>! (natürlich)
<lb xml:id="letter_0485_002_tr_1_tl_5"/>Dr. Bufetti –<pb xml:id="letter_0485_003"
                facs="https://iiif.ub.unibe.ch/image/v3/schwarzenbach/letter_0485_003.jpg"/>
            <milestone unit="textregion" xml:id="letter_0485_003_tr_2"/>
            <lb xml:id="letter_0485_003_tr_2_tl_9"/>Mr. + Mrs. Bobby Bodmer
<lb xml:id="letter_0485_003_tr_2_tl_10"/>Hotel Sonne
<lb xml:id="letter_0485_003_tr_2_tl_11"/><PAGE tag="underlined">Silvaplana</PAGE> / Engadin
<lb xml:id="letter_0485_003_tr_2_tl_12"/>Switzerland<milestone unit="textregion" xml:id="letter_0485_003_r"/>
            <lb xml:id="letter_0485_003_l_3"/>BALTIMORE. MO. 5
<lb xml:id="letter_0485_003_l"/>DEC 12
<lb xml:id="letter_0485_003_l_1"/>7.30 PM
<lb xml:id="letter_0485_003_l_2"/>1936<milestone unit="textregion" xml:id="letter_0485_003_r_1"/>
            <lb xml:id="letter_0485_003_tr_2_tl_2"/>BUY U.S. SAVINGS
<lb xml:id="letter_0485_003_tr_2_tl_4"/>BONDs
<lb xml:id="letter_0485_003_tr_2_tl_7"/>ASK YOUR POSTMASTER<pb xml:id="letter_0485_004"
                facs="https://iiif.ub.unibe.ch/image/v3/schwarzenbach/letter_0485_004.jpg"/>
            <milestone unit="textregion" xml:id="letter_0485_004_r"/><CONV tag="f">
<lb xml:id="letter_0485_004_l"/>Skizze Belvedere-Hotel</CONV><milestone unit="textregion" xml:id="letter_0485_004_r_1"/>
            <lb xml:id="letter_0485_004_l_1"/>THE BELVEDERE
<lb xml:id="letter_0485_004_l_2"/>at BALTIMORE</div>
