            <lb xml:id="letter_0895_001_tr_1_tl_2"/>Ma chère Jaqueline,
<lb xml:id="letter_0895_001_tr_1_tl_3"/>me voilà à Nyon –
<lb xml:id="letter_0895_001_tr_1_tl_4"/>je vous écris
<lb xml:id="letter_0895_001_tr_1_tl_5"/>quoique élant
<lb xml:id="letter_0895_001_tr_1_tl_6"/>très fachée avec
<lb xml:id="letter_0895_001_tr_1_tl_7"/>vous! <PAGE tag="underlined">Ecrivez</PAGE>
<lb xml:id="letter_0895_001_tr_1_tl_8"/>enfin, soyez gentille –
<lb xml:id="letter_0895_001_tr_1_tl_9"/>Milles pensées
<lb xml:id="letter_0895_001_tr_1_tl_10"/>An[emarie<milestone unit="textregion" xml:id="letter_0895_001_tr_2"/>
