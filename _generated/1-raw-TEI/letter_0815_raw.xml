<lb xml:id="letter_0815_002_l_1"/>7 Rue Sas Cases
<lb xml:id="letter_0815_002_l_2"/>Paris VII
<lb xml:id="letter_0815_002_l_3"/>France<milestone unit="textregion" xml:id="letter_0815_002_tr_2"/>
