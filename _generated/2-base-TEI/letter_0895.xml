            <milestone unit="textregion" xml:id="p001_tr_1"/>            <p xmlns:local="local" local:warning="FML-generated-to-avoid-structural-problems"> 
               <lb xml:id="p001_tr_1_tl_2"/>Ma chère Jaqueline, 
               <lb xml:id="p001_tr_1_tl_3"/>me voilà à Nyon – 
               <lb xml:id="p001_tr_1_tl_4"/>je vous écris 
               <lb xml:id="p001_tr_1_tl_5"/>quoique élant 
               <lb xml:id="p001_tr_1_tl_6"/>très fachée avec 
               <lb xml:id="p001_tr_1_tl_7"/>vous! <hi rendition="#u">Ecrivez</hi> 
               <lb xml:id="p001_tr_1_tl_8"/>enfin, soyez gentille – 
               <lb xml:id="p001_tr_1_tl_9"/>Milles pensées 
               <lb xml:id="p001_tr_1_tl_10"/>An[emarie</p>

            <milestone unit="textregion" xml:id="p001_tr_2"/>            <p xmlns:local="local" local:warning="FML-generated-to-avoid-structural-problems"> 
               <lb xml:id="p001_tr_2_tl_2"/>Mlle Nougarède 
               <lb xml:id="p001_tr_2_tl_3"/>93 Bd. St. Michel 
               <lb xml:id="p001_tr_2_tl_4"/>Paris Ve [unterstrichen und superscript e] 
               <lb xml:id="p001_tr_2_tl_5"/>.</p>

            <milestone unit="textregion" xml:id="p001_r"/>            <p xmlns:local="local" local:warning="FML-generated-to-avoid-structural-problems"> 
               <lb xml:id="p001_l"/>Stempel ? XI 29</p>

