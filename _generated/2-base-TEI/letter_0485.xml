    <text> 
      <body> 
         <div type="letter">
            <pb xml:id="p001" facs="https://iiif.ub.unibe.ch/image/v3/schwarzenbach/letter_0485_001.jpg"/>
            <milestone unit="textregion" xml:id="p001_tr_2"/>            <p xmlns:local="local" local:warning="FML-generated-to-avoid-structural-problems"> 
               <lb xml:id="p001_tr_2_tl_2"/>THE BELVEDERE 11. Dez. 36 
               <lb xml:id="p001_tr_2_tl_3"/><hi rendition="#i">at</hi> BALTIMORE</p>
            <p> 
               <lb xml:id="p001_tr_2_tl_4"/>Lieber Bobby – ganz sicher werde ich 
               <lb xml:id="p001_tr_2_tl_5"/>die prächtigen u. pfundigen U.S.A.- 
               <lb xml:id="p001_tr_2_tl_6"/>Lokomotiven für Dich photographieren – 
               <lb xml:id="p001_tr_2_tl_7"/>u. liebes Busy, ich wünschte ich 
               <lb xml:id="p001_tr_2_tl_8"/>wäre über Weihnachten mit Euch 
               <lb xml:id="p001_tr_2_tl_9"/>oben im Engadin. Ihr müsst 
               <lb xml:id="p001_tr_2_tl_10"/>alles tausendmal von mir 
               <lb xml:id="p001_tr_2_tl_11"/>grüssen!</p>
            <p> 
               <lb xml:id="p001_tr_2_tl_12"/>Erika hat am <hi rendition="#u">28.</hi> Premiere –               <!--FML: this needs attention (was tagged as "fml" in Transkribus)-->
</p>

            <milestone unit="textregion" xml:id="p001_tr_1"/>            <p xmlns:local="local" local:warning="FML-generated-to-avoid-structural-problems"> 
               <lb xml:id="p001_l"/> </p>
            <!--FML: this needs attention (was tagged as "fml" in Transkribus)-->
            <p> 
               <lb xml:id="p001_l"/>ich werde Euch Ausschnitte, 
               <lb xml:id="p001_tr_1_tl_3"/>Program[m] etc. schicken u. 
               <lb xml:id="p001_tr_1_tl_4"/>alles richtig beschreiben – 
               <lb xml:id="p001_tr_1_tl_5"/>Inzwischen haltet Ihr den 
               <lb xml:id="p001_tr_1_tl_6"/>Daumen!! –</p>
            <p> 
               <lb xml:id="p001_tr_1_tl_7"/>Ich bin hier, um über Wally 
               <lb xml:id="p001_tr_1_tl_8"/>Simpsons Heimatstadt zu 
               <lb xml:id="p001_tr_1_tl_9"/>schreiben – es ist eine sonderbare 
               <lb xml:id="p001_tr_1_tl_10"/>Geschichte, u. recht beeindruckend –</p>
            <p xmlns:local="local" local:warning="FML-generated-to-avoid-structural-problems"> 
               <lb xml:id="p001_tr_1_tl_11"/>Seid zu Neujahr gegrüsst u. 
               <lb xml:id="p001_tr_1_tl_12"/>umarmt, bleibt gesund – 
               <lb xml:id="p001_tr_1_tl_13"/>u. habt es sehr, sehr schön! 
               <lb xml:id="p001_tr_1_tl_14"/>Eure 
               <lb xml:id="p001_tr_1_tl_15"/>An[n]emarie 
               <lb xml:id="p001_tr_1_tl_16"/>WENDEN [Pfeil nach unten]</p>

            <pb xml:id="p002" facs="https://iiif.ub.unibe.ch/image/v3/schwarzenbach/letter_0485_002.jpg"/>
            <milestone unit="textregion" xml:id="p002_tr_1"/>            <p xmlns:local="local" local:warning="FML-generated-to-avoid-structural-problems"> 
               <lb xml:id="p002_tr_1_tl_1"/>Grüsst: 
               <lb xml:id="p002_tr_1_tl_2"/>Jecklin, Hans, – Lina, 
               <lb xml:id="p002_tr_1_tl_3"/>Herrn Stettler, [space] 
               <lb xml:id="p002_tr_1_tl_4"/><hi rendition="#u">Eure Buben</hi>! (natürlich) 
               <lb xml:id="p002_tr_1_tl_5"/>Dr. Bufetti –</p>

            <pb xml:id="p003" facs="https://iiif.ub.unibe.ch/image/v3/schwarzenbach/letter_0485_003.jpg"/>
            <milestone unit="textregion" xml:id="p003_tr_2"/>            <p xmlns:local="local" local:warning="FML-generated-to-avoid-structural-problems"> 
               <lb xml:id="p003_tr_2_tl_9"/>Mr. + Mrs. Bobby Bodmer 
               <lb xml:id="p003_tr_2_tl_10"/>Hotel Sonne 
               <lb xml:id="p003_tr_2_tl_11"/><hi rendition="#u">Silvaplana</hi> / Engadin 
               <lb xml:id="p003_tr_2_tl_12"/>Switzerland</p>

            <milestone unit="textregion" xml:id="p003_r"/>            <p xmlns:local="local" local:warning="FML-generated-to-avoid-structural-problems"> 
               <lb xml:id="p003_l_3"/>BALTIMORE. MO. 5 
               <lb xml:id="p003_l"/>DEC 12 
               <lb xml:id="p003_l_1"/>7.30 PM 
               <lb xml:id="p003_l_2"/>1936</p>

            <milestone unit="textregion" xml:id="p003_r_1"/>            <p xmlns:local="local" local:warning="FML-generated-to-avoid-structural-problems"> 
               <lb xml:id="p003_tr_2_tl_2"/>BUY U.S. SAVINGS 
               <lb xml:id="p003_tr_2_tl_4"/>BONDs 
               <lb xml:id="p003_tr_2_tl_7"/>ASK YOUR POSTMASTER</p>

            <pb xml:id="p004" facs="https://iiif.ub.unibe.ch/image/v3/schwarzenbach/letter_0485_004.jpg"/>
            <milestone unit="textregion" xml:id="p004_r"/>            <figure>
               <head resp="editor"> 
                  <lb xml:id="p004_l"/>Skizze Belvedere-Hotel</head>
               <bibl>
                  <persName><rs type="person" key="person_0082">Schwarzenbach, Annemarie</rs></persName>
               </bibl>
            </figure>

            <milestone unit="textregion" xml:id="p004_r_1"/>            <p xmlns:local="local" local:warning="FML-generated-to-avoid-structural-problems"> 
               <lb xml:id="p004_l_1"/>THE BELVEDERE 
               <lb xml:id="p004_l_2"/>at BALTIMORE</p>
