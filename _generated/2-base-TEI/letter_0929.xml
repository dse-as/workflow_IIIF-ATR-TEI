      <body> 
         <div type="letter">
            <pb xml:id="p001" facs="https://iiif.ub.unibe.ch/image/v3/schwarzenbach/letter_0929_002.jpg"/>
            <milestone unit="textregion" xml:id="p001_tr_1"/>            <p xmlns:local="local" local:warning="FML-generated-to-avoid-structural-problems"> 
               <lb xml:id="p001_tr_1_tl_2"/>Ma chère Jaqueline – 
               <lb xml:id="p001_tr_1_tl_3"/>je fais un voyage mer 
               <lb xml:id="p001_tr_1_tl_4" break="no"/>veilleux avec mes parents 
               <lb xml:id="p001_tr_1_tl_5"/>et mes cousins – surtout 
               <lb xml:id="p001_tr_1_tl_6"/>à Rome j'étais très heureuse 
               <lb xml:id="p001_tr_1_tl_7"/>Nous quittons Naples ce 
               <lb xml:id="p001_tr_1_tl_8"/>soir pour Milan – C'était 
               <lb xml:id="p001_tr_1_tl_9"/>déjà un commencement 
               <lb xml:id="p001_tr_1_tl_10"/>d'été, de fleurs, de soleil. – 
               <lb xml:id="p001_tr_1_tl_11"/>Comment allez-vous – quand 
               <lb xml:id="p001_tr_1_tl_12"/>avez-vous des vacances? 
               <lb xml:id="p001_l"/>Toujours Sincèrement 
               <lb xml:id="p001_l_1"/>à vous – An[emarie</p>

            <milestone unit="textregion" xml:id="p001_r"/>            <p xmlns:local="local" local:warning="FML-generated-to-avoid-structural-problems"> 
               <lb xml:id="p001_l_2"/>Mlle Jaqueline Nougarède 
               <lb xml:id="p001_l_3"/>93 Bd. St. Michel 
               <lb xml:id="p001_l_4"/>Paris V<hi rendition="#sup">e</hi></p>

            <pb xml:id="p002" facs="https://iiif.ub.unibe.ch/image/v3/schwarzenbach/letter_0929_001.jpg"/>
            <milestone unit="textregion" xml:id="p002_tr_1"/>            <p xmlns:local="local" local:warning="FML-generated-to-avoid-structural-problems"> 
               <lb xml:id="p002_tr_1_tl_1"/>NAPOLI – Piazza Vittoria</p>
