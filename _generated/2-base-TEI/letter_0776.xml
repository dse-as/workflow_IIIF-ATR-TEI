         <div type="letter">
            <pb xml:id="p001" facs="https://iiif.ub.unibe.ch/image/v3/schwarzenbach/letter_0776_001.jpg"/>
            <milestone unit="textregion" xml:id="p001_tr_1"/>            <p xmlns:local="local" local:warning="FML-generated-to-avoid-structural-problems"> 
               <lb xml:id="p001_tr_1_tl_1"/>1929/30? [mit Bleistift] 
               <lb xml:id="p001_tr_1_tl_2"/>Lieber Ernst Merz, 
               <lb xml:id="p001_tr_1_tl_3"/>ich danke Dir für die 
               <lb xml:id="p001_tr_1_tl_4"/>Schönen Sätze von 
               <lb xml:id="p001_tr_1_tl_5"/><hi rendition="#u">Hölderlin</hi>, [Bleistift] – nachdem 
               <lb xml:id="p001_tr_1_tl_6"/>die ersten Tage über 
               <lb xml:id="p001_tr_1_tl_7" break="no"/>wunden sind, fülle 
               <lb xml:id="p001_tr_1_tl_8"/>ich die Zeit mit 
               <lb xml:id="p001_tr_1_tl_9"/>Lektüre u. fühle mit 
               <lb xml:id="p001_tr_1_tl_10"/>Erstaunen dass die 
               <lb xml:id="p001_tr_1_tl_11"/><PAGE tag="continued">deutschen Romantiker</PAGE> 
               <lb xml:id="p001_tr_1_tl_12"/><PAGE tag="continued">unsere nahen Brüder</PAGE> 
               <lb xml:id="p001_tr_1_tl_13"/><PAGE tag="continued">sind –</PAGE> [Beistift] 
               <lb xml:id="p001_tr_1_tl_14"/>ich wünsche Dir schöne 
               <lb xml:id="p001_tr_1_tl_15"/>Tage u. viel Freude! 
               <lb xml:id="p001_tr_1_tl_16"/>Deine 
               <lb xml:id="p001_tr_1_tl_17"/>Annemarie</p>
</div>
       </body>
    </text>
