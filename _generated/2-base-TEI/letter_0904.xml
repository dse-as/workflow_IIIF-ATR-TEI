         <div type="letter">
            <pb xml:id="p001" facs="https://iiif.ub.unibe.ch/image/v3/schwarzenbach/letter_0904_002.jpg"/>
            <milestone unit="textregion" xml:id="p001_tr_1"/>            <p xmlns:local="local" local:warning="FML-generated-to-avoid-structural-problems"> 
               <lb xml:id="p001_tr_1_tl_1"/>Dez. 1930 
               <lb xml:id="p001_tr_1_tl_2"/>Januar 1931? [bleistift] 
               <lb xml:id="p001_tr_1_tl_3"/>Une bonne et heureuse 
               <lb xml:id="p001_tr_1_tl_4"/>nouvelle Année a vous, 
               <lb xml:id="p001_tr_1_tl_5"/>ma chère Jaqueline, 
               <lb xml:id="p001_tr_1_tl_6"/>j'espère que vos projets 
               <lb xml:id="p001_tr_1_tl_7"/>se realisent, que vous 
               <lb xml:id="p001_tr_1_tl_8"/>soyez contentes et aimée 
               <lb xml:id="p001_tr_1_tl_9"/>par tout le monde! 
               <lb xml:id="p001_tr_1_tl_10"/>Dites-moi ce que vous 
               <lb xml:id="p001_tr_1_tl_11"/>faites en ce moment, si 
               <lb xml:id="p001_tr_1_tl_13"/>vous avez passer les 
               <lb xml:id="p001_tr_1_tl_14"/>jours de fêtes chez vos 
               <lb xml:id="p001_tr_1_tl_15"/>parents et ce qui se passe 
               <lb xml:id="p001_l"/>avec Alfred – 
               <lb xml:id="p001_tr_1_tl_18"/>Je suis à Bocken et je 
               <lb xml:id="p001_tr_1_tl_20"/>travaille. En Février 
               <lb xml:id="p001_tr_1_tl_21"/>j'irai a St. Moritz 
               <lb xml:id="p001_tr_1_tl_22"/>pour me reposer – 
               <lb xml:id="p001_tr_1_tl_23"/>Tout le monde vous 
               <lb xml:id="p001_tr_1_tl_24"/>envoie ses souvenirs – 
               <lb xml:id="p001_tr_1_tl_25"/>moi je vous embrasse 
               <lb xml:id="p001_tr_1_tl_26"/>bien tendrement 
               <lb xml:id="p001_tr_1_tl_27"/>Annemarie</p>

            <pb xml:id="p002" facs="https://iiif.ub.unibe.ch/image/v3/schwarzenbach/letter_0904_001.jpg"/>
