         <div type="letter">
            <pb xml:id="p001" facs="https://iiif.ub.unibe.ch/image/v3/schwarzenbach/letter_0823_001.jpg"/>
            <milestone unit="textregion" xml:id="p001_tr_1"/>            <p xmlns:local="local" local:warning="FML-generated-to-avoid-structural-problems"> 
               <lb xml:id="p001_tr_1_tl_3"/>22. Oct. 28 
               <lb xml:id="p001_tr_1_tl_4"/>Chère Dominique – merci pour 
               <lb xml:id="p001_tr_1_tl_5"/>ta lettre. <hi rendition="#u">Reviens bientôt!</hi> 
               <lb xml:id="p001_tr_1_tl_6"/>je suis demain soir le 23 octobre, 
               <lb xml:id="p001_tr_1_tl_7"/>à Paris 93, Bd. St. -Michel, 
               <lb xml:id="p001_tr_1_tl_8"/>("Foyer des Etudiantes") V<hi rendition="#sup">e</hi>. 
               <lb xml:id="p001_tr_1_tl_10"/>Avec 2 cousines Wille. 
               <lb xml:id="p001_l"/>deux autres Vrene Reinhart 
               <lb xml:id="p001_l_1"/>et Elisabeth Rudolf, viennent 
               <lb xml:id="p001_l_2"/>en 14 jours. Mais elles n'habitent 
               <lb xml:id="p001_l_3"/>pas le "Foyer". 
               <lb xml:id="p001_tr_1_tl_19"/>j'espère te voir! et je suis 
               <lb xml:id="p001_tr_1_tl_20"/>contente que tu as si bien 
               <lb xml:id="p001_tr_1_tl_21"/>passé<del rend="overstrike">e</del> tes vacances. 
               <lb xml:id="p001_tr_1_tl_22"/>Bien des choses. 
               <lb xml:id="p001_tr_1_tl_23"/>An[emarie</p>

            <pb xml:id="p002" facs="https://iiif.ub.unibe.ch/image/v3/schwarzenbach/letter_0823_002.jpg"/>
            <milestone unit="textregion" xml:id="p002_tr_1"/>            <p xmlns:local="local" local:warning="FML-generated-to-avoid-structural-problems"> 
               <lb xml:id="p002_tr_1_tl_1"/>d</p>

            <milestone unit="textregion" xml:id="p002_r"/>            <p xmlns:local="local" local:warning="FML-generated-to-avoid-structural-problems"> 
               <lb xml:id="p002_l"/>Mlle Dominique Schlumberger 
               <lb xml:id="p002_l_1"/>c/o Mrs. Chapple 
               <lb xml:id="p002_l_2"/>Noarlunga 
               <lb xml:id="p002_l_3"/>Luardroad 
               <lb xml:id="p002_l_4"/><hi rendition="#u">Cambridge</hi> 
               <lb xml:id="p002_l_5"/>England</p>
