               <TextEquiv>
                  <Unicode>Fetan. 22 Mai 27</Unicode>
               </TextEquiv>
            </TextLine>
            <TextLine id="tr_1_tl_4"
                      custom="readingOrder {index:1;} textStyle {offset:39;length:1;strikethrough:true;}">
               <Coords points="1068,869 3345,866 3342,763 3101,741 1834,805 1064,745"/>
               <Baseline points="1083,835 1196,834 1310,835 1423,837 1537,832 1650,835 1764,839 1877,848 1991,844 2104,841 2218,835 2331,835 2445,839 2558,838 2672,835 2785,838 2899,838 3012,838 3126,835 3239,840 3353,856"/>
               <TextEquiv>
                  <Unicode>Ma chère Dominique, j'étais tres contennte de recevoir ta</Unicode>
               </TextEquiv>
            </TextLine>
            <TextLine id="tr_1_tl_5" custom="readingOrder {index:2;}">
               <Coords points="536,990 816,1050 1093,986 3214,993 3214,898 3037,944 2927,862 2423,937 536,894"/>
               <Baseline points="555,972 688,972 821,969 955,972 1088,975 1221,978 1355,978 1488,975 1621,975 1755,975 1888,978 2021,976 2155,976 2288,975 2421,975 2555,978 2688,976 2821,977 2955,981 3088,978 3222,978"/>
               <TextEquiv>
                  <Unicode>lettre – elle était si gentille et tu t'occupe tant de moi. Pourquoi?</Unicode>
               </TextEquiv>
            </TextLine>
            <TextLine id="tr_1_tl_6" custom="readingOrder {index:3;}">
               <Coords points="525,1153 3257,1146 3257,1050 2363,1075 1721,993 1298,1078 883,1011 525,1064"/>
               <Baseline points="546,1104 682,1107 818,1110 954,1110 1090,1110 1226,1112 1362,1112 1498,1112 1634,1112 1770,1112 1906,1112 2042,1112 2178,1112 2314,1114 2450,1113 2586,1113 2722,1109 2858,1111 2994,1115 3130,1115 3267,1115"/>
               <TextEquiv>
                  <Unicode>Je suis étonnee de me trouver assez bien ici sauf que j'ai toujours</Unicode>
               </TextEquiv>
            </TextLine>
            <TextLine id="tr_1_tl_7" custom="readingOrder {index:4;}">
               <Coords points="532,1284 3179,1270 3175,1174 529,1185"/>
               <Baseline points="552,1244 683,1247 815,1247 947,1250 1078,1250 1210,1250 1342,1250 1473,1250 1605,1250 1737,1250 1869,1253 2000,1253 2132,1254 2264,1256 2395,1253 2527,1253 2659,1253 2790,1256 2922,1256 3054,1262 3186,1259"/>
               <TextEquiv>
                  <Unicode>envie d'e partir pour un petit moment, pou[sic] Zurich--que veux-tu. je</Unicode>
               </TextEquiv>
            </TextLine>
            <TextLine id="tr_1_tl_8" custom="readingOrder {index:5;}">
               <Coords points="529,1405 3012,1405 2966,1309 2845,1366 2370,1295 529,1323"/>
               <Baseline points="549,1381 672,1380 796,1380 919,1380 1043,1381 1167,1381 1290,1384 1414,1387 1538,1387 1661,1387 1785,1387 1909,1387 2032,1387 2156,1390 2280,1391 2403,1385 2527,1390 2651,1393 2774,1390 2898,1390 3022,1396"/>
               <TextEquiv>
                  <Unicode>m'attache très vite à des endroits et encore plus vite a des</Unicode>
               </TextEquiv>
            </TextLine>
            <TextLine id="tr_1_tl_9" custom="readingOrder {index:6;}">
               <Coords points="532,1550 3370,1547 3345,1401 3104,1469 532,1437"/>
               <Baseline points="552,1515 693,1518 834,1515 976,1515 1117,1520 1259,1519 1400,1521 1541,1521 1683,1524 1824,1524 1966,1521 2107,1527 2248,1524 2390,1527 2531,1525 2673,1525 2814,1529 2955,1525 3097,1530 3238,1530 3380,1536"/>
               <TextEquiv>
                  <Unicode>personnes--seulement sans confiance. J'ai confiance en très peu de gens</Unicode>
               </TextEquiv>
            </TextLine>
            <TextLine id="tr_1_tl_10" custom="readingOrder {index:7;}">
               <Coords points="536,1692 3267,1678 3228,1586 532,1572"/>
               <Baseline points="552,1650 688,1656 824,1653 960,1656 1096,1659 1233,1659 1369,1659 1505,1659 1641,1661 1777,1659 1914,1659 2050,1662 2186,1664 2322,1662 2458,1665 2594,1666 2731,1668 2867,1665 3003,1665 3139,1668 3276,1668"/>
               <TextEquiv>
                  <Unicode>– même en les croyant. C'est une autre chose qui me fait peur: je sais</Unicode>
               </TextEquiv>
            </TextLine>
            <TextLine id="tr_1_tl_11" custom="readingOrder {index:8;}">
               <Coords points="539,1831 3257,1820 3228,1710 539,1742"/>
               <Baseline points="560,1793 695,1790 830,1790 965,1787 1100,1790 1236,1793 1371,1793 1506,1793 1641,1793 1776,1793 1912,1796 2047,1796 2182,1796 2317,1796 2452,1797 2587,1799 2723,1799 2858,1796 2993,1799 3128,1799 3264,1802"/>
               <TextEquiv>
                  <Unicode>que bientot ils vont me faire des déception, et bientot je vais les</Unicode>
               </TextEquiv>
            </TextLine>
            <TextLine id="tr_1_tl_12" custom="readingOrder {index:9;}">
               <Coords points="525,1948 3374,1997 3370,1884 2572,1898 2487,1827 525,1880"/>
               <Baseline points="543,1921 684,1921 826,1921 968,1923 1110,1924 1252,1927 1394,1927 1535,1927 1677,1924 1819,1927 1961,1930 2103,1933 2245,1933 2387,1933 2528,1936 2670,1936 2812,1936 2954,1933 3096,1936 3238,1936 3380,1936"/>
               <TextEquiv>
                  <Unicode>oublier. C'est triste, cela me fait del[sic]  peine et je ne sais pas comment</Unicode>
               </TextEquiv>
            </TextLine>
            <TextLine id="tr_1_tl_13" custom="readingOrder {index:10;}">
               <Coords points="514,2086 1994,2139 2114,2068 2834,2153 3104,2015 511,2008"/>
               <Baseline points="531,2052 660,2055 789,2055 918,2055 1047,2058 1176,2060 1305,2062 1434,2062 1563,2061 1692,2064 1821,2064 1950,2065 2079,2069 2208,2067 2337,2070 2466,2070 2595,2070 2724,2070 2853,2070 2982,2071 3112,2073"/>
               <TextEquiv>
                  <Unicode>me changer – alors je suis persuadée que c'est toujours ma faute –.</Unicode>
               </TextEquiv>
            </TextLine>
            <TextLine id="tr_1_tl_14" custom="readingOrder {index:11;}">
               <Coords points="521,2221 2132,2207 2519,2295 3250,2221 3250,2150 2976,2107 2792,2171 1337,2160 521,2079"/>
               <Baseline points="540,2187 675,2187 811,2187 947,2190 1083,2193 1218,2196 1354,2196 1490,2196 1626,2196 1761,2196 1897,2197 2033,2200 2169,2202 2304,2202 2440,2206 2576,2208 2712,2205 2847,2208 2983,2207 3119,2210 3255,2208"/>
               <TextEquiv>
                  <Unicode>Tu me demande si je crois en Dieu? et tu attends que je te répondes</Unicode>
               </TextEquiv>
            </TextLine>
            <TextLine id="tr_1_tl_15" custom="readingOrder {index:12;}">
               <Coords points="514,2345 3260,2377 3260,2277 2838,2246 1926,2299 954,2210 514,2281"/>
               <Baseline points="534,2318 670,2321 807,2324 943,2324 1080,2325 1217,2330 1353,2331 1490,2331 1627,2333 1763,2335 1900,2333 2037,2335 2173,2338 2310,2339 2447,2339 2583,2343 2720,2342 2857,2339 2993,2345 3130,2345 3267,2348"/>
               <TextEquiv>
                  <Unicode>– c'est difficile car je ne sais pas que dire. Oui je suis sure qu'il</Unicode>
               </TextEquiv>
            </TextLine>
            <TextLine id="tr_1_tl_16" custom="readingOrder {index:13;}">
               <Coords points="518,2508 3246,2529 3246,2419 3125,2398 1596,2423 979,2352 518,2412"/>
               <Baseline points="537,2446 672,2458 808,2458 944,2461 1080,2459 1216,2462 1352,2461 1488,2464 1624,2465 1760,2467 1896,2469 2031,2473 2167,2473 2303,2473 2439,2475 2575,2476 2711,2476 2847,2479 2983,2482 3119,2482 3255,2485"/>
               <TextEquiv>
                  <Unicode>y a une force divine – elle s'exprime dans chaque chef d'oeuvre, dans</Unicode>
               </TextEquiv>
            </TextLine>
            <TextLine id="tr_1_tl_17" custom="readingOrder {index:14;}">
               <Coords points="514,2622 3285,2636 3281,2544 3030,2501 947,2561 766,2476 511,2544"/>
               <Baseline points="531,2590 669,2593 807,2593 945,2593 1083,2596 1221,2596 1359,2598 1498,2600 1636,2601 1774,2601 1912,2604 2050,2604 2188,2607 2326,2607 2465,2610 2603,2610 2741,2613 2879,2611 3017,2616 3155,2618 3294,2622"/>
               <TextEquiv>
                  <Unicode>l'art – dans tout ce qu'on ne peut ni apprendre ni comprenne-dans tout</Unicode>
               </TextEquiv>
            </TextLine>
            <TextLine id="tr_1_tl_18" custom="readingOrder {index:15;}">
               <Coords points="514,2760 2753,2771 2657,2668 514,2678"/>
               <Baseline points="534,2730 645,2726 756,2730 867,2731 979,2733 1090,2732 1201,2733 1313,2736 1424,2736 1535,2736 1647,2739 1758,2739 1869,2739 1980,2742 2092,2747 2203,2748 2314,2748 2426,2750 2537,2748 2648,2751 2760,2754"/>
               <TextEquiv>
                  <Unicode>ce qui ce retrouve dans nos sentiments les plus nobles.</Unicode>
               </TextEquiv>
            </TextLine>
            <TextLine id="tr_1_tl_19" custom="readingOrder {index:16;}">
               <Coords points="504,2881 2998,2948 3083,2920 3083,2820 500,2785"/>
               <Baseline points="522,2858 650,2858 778,2861 907,2864 1035,2865 1164,2869 1292,2867 1421,2870 1549,2873 1678,2876 1806,2874 1934,2878 2063,2879 2191,2879 2320,2882 2448,2885 2577,2885 2705,2887 2834,2888 2962,2891 3091,2891"/>
               <TextEquiv>
                  <Unicode>D'ou' viendront-ils? Ils ne sont pas du tout logiques et ils nous</Unicode>
               </TextEquiv>
            </TextLine>
            <TextLine id="tr_1_tl_20" custom="readingOrder {index:17;}">
               <Coords points="497,3019 3196,3061 3079,2937 2721,2916 493,2934"/>
               <Baseline points="516,2995 650,2998 784,2998 919,3001 1053,3004 1188,3004 1322,3004 1456,3007 1591,3007 1725,3010 1860,3013 1994,3013 2128,3016 2263,3019 2397,3019 2532,3019 2666,3022 2800,3025 2935,3025 3069,3028 3204,3028"/>
               <TextEquiv>
                  <Unicode>donnent pas de profit – donc – La chaleur intérieure qui te rend forte</Unicode>
               </TextEquiv>
            </TextLine>
            <TextLine id="tr_1_tl_21" custom="readingOrder {index:18;}">
               <Coords points="504,3143 766,3210 915,3147 3235,3182 3203,3083 504,3072"/>
               <Baseline points="525,3130 660,3130 796,3133 932,3133 1068,3136 1203,3139 1339,3140 1475,3143 1611,3144 1746,3145 1882,3146 2018,3149 2154,3152 2289,3152 2425,3152 2561,3156 2697,3156 2832,3159 2968,3162 3104,3162 3240,3165"/>
               <TextEquiv>
                  <Unicode>c'est bien Dieu.  Moi je n'ai pas de Dieu en moi – je suis perdue aussi</Unicode>
               </TextEquiv>
            </TextLine>
            <TextLine id="tr_1_tl_22"
                      custom="readingOrder {index:19;} textStyle {offset:60;length:1;strikethrough:true;}">
               <Coords points="504,3271 3349,3331 3345,3242 2884,3196 504,3200"/>
